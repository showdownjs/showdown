# Exports for git archive
/test export-ignore
.editorconfig export-ignore
.gitattributes export-ignore
.gitignore export-ignore
eslint.config.mjs export-ignore
scripts export-ignore
.travis.yml export-ignore
.appveyor.yml export-ignore
bower.json
performance.* export-ignore

# Line endings control
# Force LF for every text file, both on checkout and in the index, on all platforms and
# regardless of the user's core.autocrlf / core.eol settings. The eol=lf attribute takes
# precedence over those git options, so CRLF can never be reintroduced in the working tree.
* text=auto eol=lf

# Binary assets: never normalize or diff
*.png binary

# Generated bundles: keep byte-stable and out of textual diffs (the build always emits LF)
bin/* binary
dist/* binary

# Fixture that deliberately contains literal CR characters as test data; git must not touch it
test/performance.testfile.md -text
