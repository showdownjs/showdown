{
  "name": "showdown",
  "version": "3.0.0-rc1",
  "description": "A Markdown to HTML converter written in Javascript",
  "author": "Estevão Santos",
  "homepage": "https://showdownjs.eu/",
  "keywords": [
    "markdown",
    "converter"
  ],
  "contributors": [
    "John Gruber",
    "John Fraser",
    "Corey Innis",
    "Remy Sharp",
    "Konstantin Käfer",
    "Roger Braun",
    "Dominic Tarr",
    "Cat Chen",
    "Titus Stone",
    "Rob Sutherland",
    "Pavel Lang",
    "Ben Combee",
    "Adam Backstrom",
    "Pascal Deschênes",
    "Estevão Santos"
  ],
  "funding": {
    "type": "individual",
    "url": "https://www.paypal.me/tiviesantos"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/showdownjs/showdown.git",
    "web": "https://github.com/showdownjs/showdown"
  },
  "license": "MIT",
  "main": "./dist/showdown.js",
  "module": "./dist/showdown.esm.js",
  "exports": {
    ".": {
      "browser": "./dist/showdown.esm.js",
      "import": "./dist/showdown.js",
      "require": "./dist/showdown.js",
      "default": "./dist/showdown.js"
    },
    "./dist/*": "./dist/*",
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=20"
  },
  "type": "commonjs",
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:test": "node scripts/build-testbundle.mjs",
    "extract:commonmark": "node scripts/extract-commonmark.mjs",
    "clean": "node -e \"require('fs').rmSync('.build',{recursive:true,force:true})\"",
    "lint": "eslint .",
    "pretest": "npm run build:test",
    "test": "npm run lint && mocha --require test/bootstrap.js \"test/unit/**/*.js\" \"test/functional/**/testsuite.*.js\"",
    "test:single": "mocha --require test/bootstrap.js",
    "perf": "node scripts/build-testbundle.mjs && node -e \"const p=require('./test/performance/performance.js');p.runTests();p.generateLogs();\""
  },
  "bin": {
    "showdown": "bin/showdown.js"
  },
  "files": [
    "bin",
    "dist"
  ],
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.10.0",
    "chai": "^4.3.6",
    "chai-match": "*",
    "commonmark-spec": "^0.31.2",
    "diffable-html": "^5.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.4",
    "globals": "^17.7.0",
    "karma": "^6.3.17",
    "karma-browserstack-launcher": "^1.6.0",
    "karma-chai": "^0.1.0",
    "karma-chrome-launcher": "^3.1.1",
    "karma-firefox-launcher": "^2.1.2",
    "karma-jsdom-launcher": "^12.0.0",
    "karma-mocha": "^2.0.1",
    "mocha": "^11.7.6",
    "performance-now": "^2.1.0",
    "sinon": "*",
    "source-map-support": "^0.5.21"
  },
  "dependencies": {
    "commander": "^9.0.0",
    "jsdom": "^19.0.0"
  },
  "overrides": {
    "minimist": "^1.2.6"
  }
}
