{
  "name": "showdown",
  "version": "3.0.0-rc2",
  "description": "A Markdown to HTML converter written in Javascript",
  "author": "Estevão Santos",
  "homepage": "https://showdownjs.eu/",
  "keywords": [
    "markdown",
    "converter"
  ],
  "contributors": [
    "John Gruber",
    "John Fraser",
    "Corey Innis",
    "Remy Sharp",
    "Konstantin Käfer",
    "Roger Braun",
    "Dominic Tarr",
    "Cat Chen",
    "Titus Stone",
    "Rob Sutherland",
    "Pavel Lang",
    "Ben Combee",
    "Adam Backstrom",
    "Pascal Deschênes",
    "Estevão Santos"
  ],
  "funding": {
    "type": "individual",
    "url": "https://www.paypal.me/tiviesantos"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/showdownjs/showdown.git",
    "web": "https://github.com/showdownjs/showdown"
  },
  "license": "MIT",
  "main": "./dist/showdown.js",
  "module": "./dist/showdown.esm.js",
  "exports": {
    ".": {
      "browser": "./dist/showdown.esm.js",
      "import": "./dist/showdown.js",
      "require": "./dist/showdown.js",
      "default": "./dist/showdown.js"
    },
    "./dist/*": "./dist/*",
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=20"
  },
  "type": "commonjs",
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:test": "node scripts/build-testbundle.mjs",
    "extract:commonmark": "node scripts/extract-commonmark.mjs",
    "clean": "node -e \"require('fs').rmSync('.build',{recursive:true,force:true})\"",
    "lint": "eslint .",
    "changelog": "node scripts/changelog.mjs",
    "test": "npm run lint && vitest run",
    "test:watch": "vitest",
    "test:single": "vitest run",
    "test:browser": "vitest run --config vitest.browser.config.mjs",
    "test:browserstack": "browserstack-node-sdk playwright test --config playwright.bstack.config.js",
    "perf": "node scripts/build-testbundle.mjs && node -e \"const p=require('./test/performance/performance.js');p.runTests();p.generateLogs();\""
  },
  "bin": {
    "showdown": "bin/showdown.js"
  },
  "files": [
    "bin",
    "dist"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@vitest/browser": "^4.1.9",
    "@vitest/browser-playwright": "^4.1.9",
    "browserstack-node-sdk": "^1.59.0",
    "commonmark-spec": "^0.31.2",
    "conventional-changelog-cli": "^5.0.0",
    "diffable-html": "^5.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "performance-now": "^2.1.0",
    "playwright": "^1.61.1",
    "semver-sort": "^1.0.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "commander": "^9.0.0",
    "jsdom": "^19.0.0"
  },
  "overrides": {
    "minimist": "^1.2.6"
  }
}
